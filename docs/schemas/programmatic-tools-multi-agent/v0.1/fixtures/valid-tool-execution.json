{
  "schema_version": "programmatic_tool_execution.v0.1",
  "contract_id": "pte-001-valid",
  "initiating_principal": "human-operator",
  "authorized_objective": "Search and summarize 3 papers on AI governance",
  "generated_program_hash": "sha256:abc123valid",
  "runtime_declaration": {
    "sandbox_type": "wasm_sandbox",
    "isolation_level": "full",
    "ephemeral": true
  },
  "allowed_tools": [
    {"tool_name": "web_search", "scope": "read-only", "max_calls": 10},
    {"tool_name": "summarize", "scope": "in-memory", "max_calls": 5}
  ],
  "permissions": {
    "network": "allowlist",
    "filesystem": "read_only",
    "subprocess": "denied",
    "code_execution": "sandboxed",
    "secret_access": "prohibited"
  },
  "boundaries": {
    "input_boundary": "search query string",
    "intermediate_data_boundary": "search results and summaries only",
    "retained_intermediate_results": ["search_results", "summaries"],
    "discarded_intermediate_results": ["raw_html"],
    "discard_policy": "raw HTML discarded after extraction; summaries retained"
  },
  "resource_limits": {
    "max_steps": 20,
    "max_duration_seconds": 120,
    "max_tokens": 50000,
    "max_cost_usd": 0.50,
    "max_memory_mb": 512,
    "max_output_size_mb": 10
  },
  "stop_cancel_behavior": {
    "cancel_propagation": "immediate",
    "partial_result_policy": "discard",
    "timeout_behavior": "discard"
  },
  "failure_handling": {
    "on_tool_failure": "skip",
    "on_budget_exceeded": "abort",
    "on_sandbox_violation": "quarantine",
    "replay_posture": "best_effort"
  },
  "validation_requirements": {
    "output_validation": true,
    "tool_scope_verification": true,
    "evidence_completeness_check": true
  },
  "evidence_requirements": {
    "tool_invocations_logged": true,
    "material_decisions_logged": true,
    "discarded_data_policy_enforced": true,
    "receipt_required": true
  }
}
