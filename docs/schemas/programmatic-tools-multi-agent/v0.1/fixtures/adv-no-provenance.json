{
  "schema_version": "multi_agent_execution.v0.1",
  "contract_id": "mae-bad-no-provenance",
  "orchestrator": {
    "identity": "human-via-orchestrator",
    "authority": "delegated-by-human",
    "synthesis_responsibility": true
  },
  "subagents": [
    {
      "role": "researcher",
      "objective": "find papers",
      "inherited_permissions": ["web_search:read-only"],
      "reduced_permissions": true,
      "context_mode": "isolated",
      "evidence_attribution": false,
      "timeout_seconds": 60
    }
  ],
  "concurrency_limits": {
    "max_fan_out": 3,
    "max_concurrent": 2,
    "straggler_timeout_seconds": 30
  },
  "communication_topology": {
    "topology_type": "star",
    "inter_agent_messaging": false,
    "shared_state": false
  },
  "conflict_handling": {
    "contradiction_policy": "flag",
    "resolution_authority": "orchestrator",
    "unresolved_uncertainty_logged": true
  },
  "cancellation_propagation": {
    "propagation_type": "immediate_all",
    "partial_cancellation_handling": "abort_all",
    "timeout_handling": "accept_partial"
  },
  "resource_accounting": {
    "per_agent_tracking": true,
    "aggregate_tracking": true,
    "cost_attribution": true
  },
  "final_gate": {
    "gate_type": "automated",
    "acceptance_criteria": "output received",
    "rejection_policy": "discard"
  }
}
